NODE_ENV=production
PORT=3001
DATABASE_URL=postgres://usuario:senha@localhost:5432/nome_do_banco
JWT_SECRET=sua_chave_secreta_jwt_segura_aqui
FRONTEND_URL=https://seu-dominio.example

# Opcional: cria o primeiro administrador apenas se ainda nao existir.
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=defina_uma_senha_forte_aqui
INITIAL_ADMIN_COMPANY_ID=12.345.678/0001-90

# Push Notifications / PWA
# Gere com: node -e "const webpush=require('web-push'); console.log(webpush.generateVAPIDKeys())"
VAPID_PUBLIC_KEY=cole_a_chave_publica_aqui
VAPID_PRIVATE_KEY=cole_a_chave_privada_aqui
VAPID_SUBJECT=mailto:seuemail@seudominio.com.br
