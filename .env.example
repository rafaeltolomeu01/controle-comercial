DATABASE_URL=postgresql://usuario:senha@host:5432/banco
JWT_SECRET=troque_esta_chave
PORT=3000

# Push Notifications / PWA
# Gere com: node -e "const webpush=require('web-push'); console.log(webpush.generateVAPIDKeys())"
VAPID_PUBLIC_KEY=cole_a_chave_publica_aqui
VAPID_PRIVATE_KEY=cole_a_chave_privada_aqui
VAPID_SUBJECT=mailto:seuemail@seudominio.com.br

# Upload externo de fotos/arquivos (recomendado para nao encher o PostgreSQL)
# Crie um upload preset unsigned no Cloudinary e preencha:
CLOUDINARY_CLOUD_NAME=seu_cloud_name
CLOUDINARY_UPLOAD_PRESET=seu_upload_preset
CLOUDINARY_FOLDER=controle-comercial

# Se quiser bloquear salvamento no banco quando o upload externo falhar:
# UPLOAD_EXTERNAL_REQUIRED=true
